# Copy to .env (repo root) and fill in your keys.
# Without keys the server starts in MOCK mode with fake data.

# --- Twitch: currently DISABLED in code. Kept here for when it's re-enabled.
#     (https://dev.twitch.tv/console/apps -> Register Your Application,
#      OAuth Redirect URL can be http://localhost, Category: Analytics Tool)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- YouTube (https://console.cloud.google.com -> create a project ->
#     enable "YouTube Data API v3" -> Credentials -> API key)
YOUTUBE_API_KEY=

# YouTube tracked searches are now managed in the UI (Settings tab) and stored
# in the browser, not here. CATEGORIES (Twitch) is only used if Twitch is
# re-enabled; the in-code default seeds the initial list.

# Force mode: auto | true | false (auto = mock when no keys at all)
MOCK=auto

PORT=8080
DB_PATH=./data/analytics.db
# Twitch poll interval (seconds), used only when Twitch is re-enabled.
# 900 = 15 min gives good trends without load.
POLL_INTERVAL_SEC=900
# YouTube is polled less often due to quota (search.list = 100 units,
# limit 10000/day). 14400 = 4 hours.
YT_POLL_INTERVAL_SEC=14400
# Pages of 100 streams to pull per Twitch category.
MAX_PAGES_PER_GAME=2
